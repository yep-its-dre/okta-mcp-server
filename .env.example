# Okta org domain. Use the native Okta domain, not your custom login domain.
OKTA_DOMAIN=dev-12345678.okta.com

# Okta API service app using client credentials.
# Required scopes for read-only demos:
# okta.users.read okta.groups.read okta.logs.read okta.apps.read
OKTA_CLIENT_ID=replace_me

# Okta service apps for Okta APIs normally require private_key_jwt.
# Generate a key pair locally and add the public JWK to the Okta service app.
OKTA_PRIVATE_KEY_FILE=./keys/okta-mcp-readonly-private.pem
OKTA_KEY_ID=replace_me

# Legacy/fallback only. Do not use if your org requires private_key_jwt.
# OKTA_CLIENT_SECRET=replace_me

# Optional Slack bot token for Slack investigation tools.
# Required Slack scopes depend on workspace settings; common read-only scopes:
# users:read users:read.email
SLACK_BOT_TOKEN=xoxb-replace-me

# Required for the optional Slack bot UI when running locally with Socket Mode.
# Create an app-level token with connections:write.
SLACK_APP_TOKEN=xapp-replace-me

# Required when using an org-level Slack token on Enterprise Grid.
# Slack users.list ignores this for workspace-level tokens.
SLACK_TEAM_ID=T00000000

# Optional comma-separated names of Okta groups that grant Slack access.
SLACK_OKTA_ACCESS_GROUPS=app-default-users,app-contractor-default-users,app-slack-users

# Local JSONL audit log for MCP tool calls.
AUDIT_LOG_PATH=./audit.log
