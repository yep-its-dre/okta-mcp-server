{
  "name": "okta-mcp-server",
  "version": "1.0.0",
  "description": "Read-only Okta and Slack MCP tools for IT operations demos.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "slack:bot": "tsx --env-file=.env src/slack-bot.ts",
    "slack:bot:start": "node --env-file=.env dist/slack-bot.js",
    "check:connections": "tsx --env-file=.env scripts/check-connections.ts",
    "generate:okta-key": "tsx scripts/generate-okta-key.ts",
    "debug:okta-assertion": "tsx --env-file=.env scripts/debug-okta-assertion.ts",
    "slack:auth-test": "tsx --env-file=.env scripts/slack-auth-test.ts",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "okta",
    "slack",
    "iam",
    "it-operations"
  ],
  "author": "Andre O'Sullivan",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.7.3",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
